<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>InvestMS - AI Powered Investment Management System</display-name>
    <description>Enterprise investment management system with AI features</description>

    <!-- ═══════════════════════════════════════════════════════
         WELCOME FILE — Redirect root to login
    ═══════════════════════════════════════════════════════ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ═══════════════════════════════════════════════════════
         SESSION CONFIGURATION — 30 minute timeout
    ═══════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure><!-- Set to true in production with HTTPS -->
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ═══════════════════════════════════════════════════════
         SERVLET MAPPINGS (annotation-based, listed for clarity)
    ═══════════════════════════════════════════════════════ -->

    <!-- Auth Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.investms.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.investms.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.investms.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.investms.servlet.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/ProfileServlet</url-pattern>
    </servlet-mapping>

    <!-- Dashboard Servlet -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.investms.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/DashboardServlet</url-pattern>
    </servlet-mapping>

    <!-- Portfolio Servlet -->
    <servlet>
        <servlet-name>PortfolioServlet</servlet-name>
        <servlet-class>com.investms.servlet.PortfolioServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PortfolioServlet</servlet-name>
        <url-pattern>/PortfolioServlet</url-pattern>
    </servlet-mapping>

    <!-- Investment Servlet -->
    <servlet>
        <servlet-name>InvestmentServlet</servlet-name>
        <servlet-class>com.investms.servlet.InvestmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InvestmentServlet</servlet-name>
        <url-pattern>/InvestmentServlet</url-pattern>
    </servlet-mapping>

    <!-- Transaction Servlet -->
    <servlet>
        <servlet-name>TransactionServlet</servlet-name>
        <servlet-class>com.investms.servlet.TransactionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TransactionServlet</servlet-name>
        <url-pattern>/TransactionServlet</url-pattern>
    </servlet-mapping>

    <!-- Notification Servlet -->
    <servlet>
        <servlet-name>NotificationServlet</servlet-name>
        <servlet-class>com.investms.servlet.NotificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NotificationServlet</servlet-name>
        <url-pattern>/NotificationServlet</url-pattern>
    </servlet-mapping>

    <!-- AI Servlet -->
    <servlet>
        <servlet-name>AIServlet</servlet-name>
        <servlet-class>com.investms.servlet.AIServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AIServlet</servlet-name>
        <url-pattern>/AIServlet</url-pattern>
    </servlet-mapping>

    <!-- ═══════════════════════════════════════════════════════
         ERROR PAGES
    ═══════════════════════════════════════════════════════ -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/error/403.jsp</location>
    </error-page>

    <!-- ═══════════════════════════════════════════════════════
         SECURITY CONSTRAINT — Prevent direct JSP access
    ═══════════════════════════════════════════════════════ -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Protected JSP includes</web-resource-name>
            <url-pattern>/includes/*</url-pattern>
        </web-resource-collection>
        <auth-constraint/><!-- No roles = deny all direct access -->
    </security-constraint>

    <!-- ═══════════════════════════════════════════════════════
         MIME TYPES
    ═══════════════════════════════════════════════════════ -->
    <mime-mapping>
        <extension>json</extension>
        <mime-type>application/json</mime-type>
    </mime-mapping>
    <mime-mapping>
        <extension>woff2</extension>
        <mime-type>font/woff2</mime-type>
    </mime-mapping>

    <!-- ═══════════════════════════════════════════════════════
         CHARACTER ENCODING FILTER
    ═══════════════════════════════════════════════════════ -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>com.investms.filter.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

</web-app>
